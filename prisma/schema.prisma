// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider     = "postgresql"
  relationMode = "prisma"
}

// #region Enums
enum VendorServices {
  ROS
  Towing
}

enum OtpType {
  Number
  Email
}

enum VendorStatus {
  Pending
  Approved
}

enum DriverStatus {
  Available
  Busy
  UnderApproval
  Banned
}

enum FleetType {
  Private
  Public
}

enum Role {
  SuperAdmin
  Admin
  Vendor
  Driver
  Customer
}

// #region Tables
model vendor {
  id                   Int              @id @default(autoincrement())
  formated_id          String           @unique
  full_name            String           @db.VarChar(255)
  email                String           @unique @db.VarChar(255)
  number               String           @unique @db.VarChar(20)
  password             String           @db.VarChar(255)
  is_email_verified    Boolean          @default(true)
  is_number_verified   Boolean          @default(true)
  is_gst_vendor        Boolean          @default(false)
  vendor_image_url     String           @db.Text()
  services             VendorServices[]
  pan_card_url         String           @db.Text()
  adhar_card_url       String           @db.Text()
  org_name             String           @db.VarChar(255)
  org_number           String           @db.VarChar(20)
  org_alternate_number String           @db.VarChar(20)
  org_email            String           @unique @db.VarChar(255)
  org_certificate_url  String           @db.Text()
  gst_number           String           @db.VarChar(15)
  gst_certificate_url  String           @db.Text()
  approved_by          Int? // Admin id 
  is_deleted           Boolean          @default(false)
  status               VendorStatus     @default(Pending)
  created_at           DateTime         @default(now())
  updated_at           DateTime         @default(now()) @updatedAt
  is_deleted_by        Int?

  bank_detail vendor_bank_detail?

  @@index([id, formated_id])
}

model vendor_bank_detail {
  id                  Int    @id @default(autoincrement())
  vendor_id           Int    @unique
  account_number      String
  ifsc_code           String
  bank_name           String
  branch_name         String
  account_holder_name String
  detail_url          String @db.Text()

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  vendor vendor @relation(fields: [vendor_id], references: [id], onDelete: Cascade)

  @@index([vendor_id])
}

model otp {
  id         Int      @id @default(autoincrement())
  otp        String   @db.VarChar(6)
  number     String?  @db.VarChar(20)
  email      String?  @db.VarChar(255)
  type       OtpType
  expires_at DateTime
  created_at DateTime @default(now())
}

model driver {
  id                 Int     @id @default(autoincrement())
  formated_id          String           @unique
  vendor_id Int
  full_name          String  @db.VarChar(255)
  number             String  @unique @db.VarChar(20)
  alternate_number   String  @db.VarChar(20)
  email              String  @unique @db.VarChar(255)
  password           String  @db.VarChar(255)
  is_email_verified  Boolean @default(false)
  is_number_verified Boolean @default(false)
  adhar_card_url     String  @db.Text()
  pan_card_url       String  @db.Text()
  driver_license_url String  @db.Text()
  is_deleted         Boolean @default(false)
  created_at         DateTime @default(now())
  updated_at         DateTime @default(now()) @updatedAt
  is_deleted_by      Int?
  status             DriverStatus @default(Busy)
  
  @@index([id, formated_id])
}

model vehicle {
  id                  Int       @id @default(autoincrement())
  fleet_type          FleetType @default(Private)
  vendor_id           Int
  fleet_location      String    @db.VarChar(255)
  registration_number String    @unique @db.VarChar(20)
  make                String    @db.VarChar(255) // Company name
  model               String    @db.VarChar(255)
  owner_name          String    @db.VarChar(255)
  chassis_number      String    @unique @db.VarChar(255)
  engine_number       String    @unique @db.VarChar(255)
  vehicle_validity    DateTime
  insurance_validity  DateTime
  fitness_validity    DateTime
  puc_validity        DateTime
  vehical_image_url   String[]
  chassis_image_url   String[]
  tax_image_url       String[]
  insurance_image_url String[]
  fitness_image_url   String[]
  puc_image_url       String[]
  is_deleted          Boolean   @default(false)
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now()) @updatedAt

  @@index([id])
}
