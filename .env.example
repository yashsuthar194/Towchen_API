# ============================================
# Storage Service Configuration
# ============================================

# Storage Provider (optional, defaults to 'cloudflare-r2')
# Options: cloudflare-r2, aws-s3 (future), azure-blob (future)
STORAGE_PROVIDER=cloudflare-r2

# ============================================
# CloudFlare R2 Configuration
# ============================================

# Your CloudFlare Account ID
# Found in: CloudFlare Dashboard > R2 > Overview
R2_ACCOUNT_ID=your-account-id-here

# R2 API Token Access Key ID
# Create at: CloudFlare Dashboard > R2 > Manage R2 API Tokens
R2_ACCESS_KEY_ID=your-access-key-id-here

# R2 API Token Secret Access Key
R2_SECRET_ACCESS_KEY=your-secret-access-key-here

# R2 Bucket Name
# The name of your R2 bucket where files will be stored
R2_BUCKET_NAME=your-bucket-name-here

# Optional: Public URL for your R2 bucket
# Only needed if you've configured a custom domain for your bucket
# Example: https://files.yourdomain.com
# R2_PUBLIC_URL=https://files.yourdomain.com
# ============================================
# Twilio SMS Service Configuration
# ============================================

TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# ============================================
# Mail Service Configuration
# ============================================
# Set MAIL_PROVIDER to choose the active email provider.
# Options: nodemailer | resend

# --- Option A: Nodemailer (SMTP) ---
# MAIL_PROVIDER=nodemailer
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USER=your-smtp-user@example.com
# MAIL_PASS=your-smtp-password
# MAIL_FROM=noreply@example.com

# --- Option B: Resend ---
# MAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# MAIL_FROM=noreply@yourdomain.com
# Note: MAIL_FROM must use a verified domain in your Resend dashboard.
# During development you can use: onboarding@resend.dev (sends to your account email only)

# --- Option C: SendGrid ---
# MAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
# MAIL_FROM=noreply@yourdomain.com
# Note: MAIL_FROM must match a verified Sender Identity in your SendGrid account.
